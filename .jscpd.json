{
  "absolute": true,
  "blame": true,
  "gitignore": true,
  "ignore": [
    "**/*.config.js",
    "**/*.config.mjs",
    "**/*.min.js",
    "**/*.spec.ts",
    "**/*.test.ts",
    "coverage/**",
    "dist/**",
    "build/**",
    "node_modules/**",
    "**/package.json",
    "**/tsconfig.json",
    "**/tsconfig.*.json",
    "**/.husky/**",
    "**/.mise.toml",
    "**/.specs/**",
    "**/target/**",
    "**/*.d.ts",
    "**/index.js"
  ],
  "output": ".jscpd",
  "reporters": ["console", "html"],
  "silent": false,
  "threshold": 1
}
